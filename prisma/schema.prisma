generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  username     String    @unique
  password     String
  role         String    @default("EDITOR")
  status       String    @default("ACTIVE")
  profileImage String?
  lastLogin    DateTime?
  dateCreated  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model NewsArticle {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  category      String    @default("General")
  date          String
  readTime      String    @default("5 min read")
  content       String?
  image         String
  excerpt       String
  featured      Boolean   @default(false)
  status        String    @default("DRAFT")
  contentBlocks Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  metaTitle     String?
  metaDescription String?
  tags          String[]
  author        String?
  comments      Comment[]
}

model Project {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  industry          String
  duration          String
  location          String
  description       String
  deliverables      Json
  image             String
  category          String
  featured          Boolean   @default(false)
  status            String    @default("Planned")
  publicationStatus String    @default("DRAFT")
  startDate         DateTime?
  endDate           DateTime?
  client            String?
  objectives        Json?
  technologies      Json?
  achievements      Json?
  gallery           Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  metaTitle         String?
  metaDescription   String?
  readingTime       Int?
  tags              String[]
  author            String?
  comments          Comment[]
}

model Service {
  id               String                @id @default(cuid())
  title            String
  slug             String                @unique
  shortDescription String
  fullDescription  String
  category         String
  icon             String
  featured         Boolean               @default(false)
  order            Int                   @default(0)
  status           String                @default("DRAFT")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  banner           String?
  comments         Comment[]
  features         ServiceFeature[]
  illustrations    ServiceIllustration[]
}

model ServiceIllustration {
  id        String  @id @default(cuid())
  url       String
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model ServiceFeature {
  id          String  @id @default(cuid())
  title       String
  description String
  icon        String
  serviceId   String
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Career {
  id                String        @id @default(cuid())
  title             String
  slug              String        @unique
  department        String
  location          String
  employmentType    String
  experienceLevel   String
  excerpt           String
  descriptionBlocks Json?
  responsibilities  Json
  requirements      Json
  salaryRange       String?
  deadline          DateTime
  status            String        @default("OPEN")
  featured          Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  applications      Application[]
}

model Application {
  id            String   @id @default(cuid())
  careerId      String
  fullName      String
  email         String
  phone         String
  coverLetter   String
  cvName        String?
  cvSize        Int?
  cvType        String?
  cvData        String?
  portfolioLink String?
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  career        Career   @relation(fields: [careerId], references: [id], onDelete: Cascade)
}

model Comment {
  id             String       @id @default(cuid())
  contentType    String
  fullName       String
  email          String
  text           String       @map("content")
  status         String       @default("PENDING")
  ipAddress      String?
  isEdited       Boolean      @default(false)
  isCompanyReply Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  newsArticleId  String?
  projectId      String?
  serviceId      String?
  parentId       String?
  newsArticle    NewsArticle? @relation(fields: [newsArticleId], references: [id], onDelete: Cascade)
  parent         Comment?     @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Comment[]    @relation("CommentReplies")
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service        Service?     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Subscriber {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  source         String   @default("FOOTER")
  status         String   @default("SUBSCRIBED")
  dateSubscribed DateTime @default(now())
}

model Campaign {
  id             String    @id @default(cuid())
  title          String
  subject        String
  content        String
  featuredImage  String?
  status         String    @default("DRAFT")
  sentAt         DateTime?
  recipientCount Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model CompanyInfo {
  id          String   @id @default("singleton")
  name        String
  tagline     String
  description String
  email       String
  phone       String
  address     String
  socialLinks Json
  updatedAt   DateTime @updatedAt
}

model PageContent {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt
}
